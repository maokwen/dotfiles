[Desktop Entry]
Name=Typora
GenericName=Markdown Editor
Exec=typora --enable-features=UseOzonePlatform --ozone-platform=wayland --enable-wayland-ime --enable-webrtc-pipewire-capturer %U
Icon=typora
Type=Application
StartupNotify=true
Categories=Office;WordProcessor;
MimeType=text/markdown;text/x-markdown;

